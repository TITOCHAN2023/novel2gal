# ============================================================
# Novel2Gal 环境配置
# 复制此文件为 .env 并填写你的值
# ============================================================

# ---- LLM（必填）----
# LM Studio / vLLM / Ollama 等 OpenAI 兼容 API
LLM_BASE_URL=http://localhost:1234
LLM_MODEL=                    # 留空=自动用服务器上第一个模型
LLM_TIMEOUT=600               # 单次 LLM 请求超时（秒）

# ---- 解析 ----
CHUNK_MAX_CHARS=3000          # 每个文本块最大字符数
CHUNK_OVERLAP_CHARS=200       # 块间重叠字符数

# ---- 生图（可选）----
# AnyGen API key（不填则跳过图片生成）
ANYGEN_API_KEY=
IMAGE_MAX_CONCURRENT=8        # 生图最大并发数

# ---- TTS 语音合成（可选）----
TTS_ENABLED=false             # 是否启用 TTS
TTS_PROVIDER=                 # edge_tts(免费默认) / openai / volcano / cosyvoice
TTS_MAX_CONCURRENT=4          # TTS 最大并发数

# OpenAI TTS（如果 TTS_PROVIDER=openai）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# 火山引擎 TTS（如果 TTS_PROVIDER=volcano）
VOLCANO_TTS_APP_ID=
VOLCANO_TTS_TOKEN=

# CosyVoice（如果 TTS_PROVIDER=cosyvoice）
COSYVOICE_BASE_URL=http://localhost:50000

# ---- 其他 ----
# 小说文件路径（仅供参考，实际通过前端上传）
NOVEL_EPUB_PATH=
